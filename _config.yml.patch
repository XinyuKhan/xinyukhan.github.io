mathjax:
  tags: none # or 'ams' or 'all'
  single_dollars: true # enable single dollar signs as in-line math
  cjk_width: 0.9 # relative CJK char width
  normal_width: 0.6 # relative normal (alnum) width
  append_css: true # add CSS to every page
  every_page: false # if true, every page will be rendered by mathjax regardless of the `mathjax` setting in Front-matter
